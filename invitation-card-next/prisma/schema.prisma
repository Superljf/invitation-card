// Prisma schema for invitation_db (MySQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Invitation {
  id         String   @id @db.VarChar(32)
  templateId Int      @map("template_id")
  formData   String   @map("form_data") @db.Text
  createdAt  DateTime? @map("created_at") @default(now())

  @@map("invitation")
}
